# ── Alpaca ──────────────────────────────────────────────────────────────────
# https://app.alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ALPACA_PAPER=true                  # 실거래 전환 시 false

# ── Telegram (기존 @Lensreportbot 그대로 사용) ────────────────────────────
TELEGRAM_TOKEN=1234567890:ABCDEFxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── LENS 신호 파일 경로 ──────────────────────────────────────────────────
# LENS 프로젝트 루트 기준 상대경로 또는 절대경로
LENS_SIGNALS_PATH=signals.json

# ── 리스크 파라미터 ──────────────────────────────────────────────────────
MAX_POSITION_PCT=0.05       # 포트폴리오 대비 최대 포지션 비율 (5%)
STOP_LOSS_PCT=0.03          # 스탑로스 비율 (3%)
MIN_SIGNAL_STRENGTH=0.70    # 최소 신호 강도 (70%)
MIN_BUYING_POWER=500        # 최소 매수여력 ($)

# ── 스케줄러 ────────────────────────────────────────────────────────────
POLL_INTERVAL=60            # signals.json 폴링 간격 (초)
